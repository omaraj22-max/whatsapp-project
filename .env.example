# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# App
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
APP_PASSWORD="your-admin-password"

# Meta / WhatsApp Business API
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
META_PHONE_NUMBER_ID="your-phone-number-id"
META_WHATSAPP_BUSINESS_ACCOUNT_ID="your-waba-id"
META_ACCESS_TOKEN="your-permanent-access-token"
META_WEBHOOK_VERIFY_TOKEN="your-custom-verify-token"

# Monday.com
MONDAY_API_TOKEN="your-monday-api-token"
MONDAY_BOARD_ID="your-board-id"
MONDAY_WEBHOOK_SECRET="your-monday-webhook-secret"

# OpenAI
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o"
OPENAI_SYSTEM_PROMPT="Eres un asistente de ventas amable y profesional. Tu objetivo es calificar leads y responder preguntas sobre nuestros productos."
